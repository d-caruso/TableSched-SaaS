{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "types": ["jest"],
    "paths": {
      "@/*": ["./*", "node_modules/tablesched-frontend/*"],
      "@core/*": ["node_modules/tablesched-frontend/*"],
      "@saas/*": ["./*"],
      "sentry-expo": ["node_modules/sentry-expo"],
      "expo-image-picker": ["__mocks__/expo-image-picker"]
    }
  },
  "exclude": [
    "dist",
    ".expo",
    "node_modules",
    "../../TableSched/frontend"
  ]
}
